{
  "name": "fullscream",
  "version": "1.0.1",
  "description": "Helps go fullscreen",
  "keywords": [
    "fullscreen",
    "screenfull"
  ],
  "main": "index.js",
  "module": "index.es",
  "homepage": "https://github.com/thewhodidthis/fullscream#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/fullscream.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/fullscream/issues"
  },
  "scripts": {
    "test": "browserify test/*.js | testling -x open",
    "clear": "npm run clear:dist && npm run clear:logs",
    "clear:dist": "rm -rf dist/",
    "clear:logs": "rm -f *.log",
    "lint": "eslint index.es; exit 0",
    "lint:test": "eslint test/index.js; exit 0",
    "start": "npm run build && npm run build:min",
    "build": "rollup -c",
    "build:min": "uglifyjs dist/fullscream.js -cm > dist/fullscream.min.js",
    "preversion": "npm start"
  },
  "engines": {
    "node": ">=4.2.4",
    "npm": ">=3.5.3"
  },
  "dependencies": {},
  "devDependencies": {
    "babel-eslint": "latest",
    "babel-plugin-external-helpers": "latest",
    "babel-preset-es2015": "latest",
    "browserify": "latest",
    "eslint": "latest",
    "eslint-config-airbnb-base": "latest",
    "eslint-plugin-import": "latest",
    "rollup": "latest",
    "rollup-plugin-babel": "latest",
    "tape": "latest",
    "testling": "latest",
    "uglify-js": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
